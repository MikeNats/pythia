# Template — copy to .env and fill in real values.  Commit THIS file, not .env.
# Every var maps to a field on app/core/config.py:Settings (case-insensitive).

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://docqapp:docqapp@localhost:5434/docqapp
DB_ECHO=false                       # true = log every SQL statement

# ── LLM providers ─────────────────────────────────────────
ANTHROPIC_API_KEY=                  # sk-ant-...  (leave empty to use Ollama only)
DEFAULT_CLAUDE_MODEL=claude-sonnet-4-6

OLLAMA_HOST=http://localhost:11434
LLAMA_DEFAULT_MODEL=llama3.2

LLM_TIMEOUT=60                      # seconds per LLM call
LLM_MAX_RETRIES=3                   # SDK retries on 429 / 5xx / network

# ── Observability / audit ─────────────────────────────────
LOGGING=true                        # false = mute console log (DB rows still written)
LOGGING_LEVEL=INFO
AUDIT_REQUEST_BODIES=true           # false = don't store request payloads (PHI control)
AUDIT_MAX_BODY_BYTES=8192           # cap on captured body size
